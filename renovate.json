{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"dependencyDashboard": true,
	"packageRules": [
		{
			"matchFileNames": [
				".github/workflows/ci-pinning.yml"
			],
			"pinDigests": true
		},
		{
			"description": "helpers:pinGitHubActionDigestsToSemver",
			"matchFileNames": [
				".github/workflows/ci-pinning-best-practices.yml"
			],
			"matchDepTypes": [
				"action"
			],
			"pinDigests": true
		},
		{
			"description": "helpers:pinGitHubActionDigestsToSemver",
			"matchDepTypes": [
				"action"
			],
			"pinDigests": true,
			"extractVersion": "^(?<version>v?\\d+\\.\\d+\\.\\d+)$"
		},
		{
			"matchPackageNames": [
				"astral-sh/setup-uv"
			],
			"versioning": "github-actions"
		}
	]
}
